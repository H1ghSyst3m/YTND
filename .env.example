# Required
MANAGER_SECRET="change-me-to-a-random-secret"

# Manager server
MANAGER_HOST="0.0.0.0"
MANAGER_PORT="8080"
# MANAGER_BASE_URL="http://localhost:8080"

# Data paths
# DATA_ROOT="./data"
# OUTPUT_ROOT="data/downloads"
# COVERS_ROOT="data/covers"
# LOG_DIR="data/logs"
# DATABASE_FILE="data/ytnd.db"
# COOKIES_FILE="data/cookies.txt"

# Optional: only set when ffmpeg is not available in PATH
# FFMPEG_PATH="/usr/bin/ffmpeg"

# Optional: YouTube currently requires a supported JavaScript runtime for some downloads.
# Deno is recommended. Leave unset to auto-detect deno, node, or qjs in PATH.
# YTND_JS_RUNTIME="auto"
# YTND_JS_RUNTIME_PATH="/usr/local/bin/deno"

# Optional: YouTube cookies must be a Netscape-format cookies.txt file.
# Export from a private/incognito YouTube session after opening https://www.youtube.com/robots.txt,
# then close that private window so the exported session is not rotated by the browser.

# Optional: enable WebDAV endpoint
WEBDAV_ENABLED="false"

# Optional: auto-create first admin if no users exist
# INITIAL_ADMIN_USERNAME="admin"
# INITIAL_ADMIN_PASSWORD="changeme123"
