# REQUIRED
MANAGER_SECRET=change-me-to-a-random-secret

# OPTIONAL: Auto-create first admin on startup (if no users exist)
# INITIAL_ADMIN_USERNAME="admin"
# INITIAL_ADMIN_PASSWORD="changeme123"

# Server
MANAGER_HOST=0.0.0.0
MANAGER_PORT=8080
WEBDAV_ENABLED=false

# Paths (optional, defaults to ./data)
# DATA_ROOT="./data"
# FFMPEG_PATH=""
